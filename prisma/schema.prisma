generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int      @id @default(autoincrement())
  key          String   @unique @default(uuid())
  email        String   @unique
  password     String
  refreshToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Genre {
  id     Int          @id
  name   String       @unique
  movies MovieGenre[]
}

model Movie {
  id               Int          @id
  title            String
  overview         String?
  releaseDate      DateTime?
  posterPath       String?
  backdropPath     String?
  originalLanguage String?
  popularity       Float?
  tmdbVoteAverage  Float?
  tmdbVoteCount    Int?
  genres           MovieGenre[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([title])
  @@index([popularity])
}

model MovieGenre {
  movieId Int
  genreId Int
  movie   Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)
  genre   Genre @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([movieId, genreId])
  @@index([genreId])
}
